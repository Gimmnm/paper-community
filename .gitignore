# --- OS / 编辑器 ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Python 通用 ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dylib
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.pytest_cache/
.ipynb_checkpoints/

# --- 虚拟环境 / 凭据 ---
.venv/
venv/
.env
*.env

